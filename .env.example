# Adobe Target MCP server configuration.
# Copy to .env for local use, or set these in your MCP client's "env" block.
# Get credentials from an OAuth Server-to-Server project in the
# Adobe Developer Console (https://developer.adobe.com/console) with the
# Adobe Target API enabled.

# Client ID of your Adobe Developer Console project (also used as the API key)
ADOBE_CLIENT_ID=your-client-id
ADOBE_API_KEY=your-client-id

# Client secret of your Adobe Developer Console project
ADOBE_CLIENT_SECRET=your-client-secret

# Your Adobe Target tenant — the subdomain in mc.adobe.io/<tenant>/target/...
ADOBE_TENANT=your-tenant

# Optional: port for --sse / --streamable-http modes (default 3001)
# PORT=3001

# Optional: enable verbose per-tool logging
# MCP_TOOL_LOGGING=true

# Optional: log file path when running in stdio mode
# MCP_LOG_FILE=/tmp/adobe-target-mcp.log
